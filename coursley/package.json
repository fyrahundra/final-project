		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.2.7",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"playwright": "^1.58.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"storybook": "^10.2.7",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
